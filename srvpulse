#!/bin/bash
# srvpulse - server resource monitor CLI
#
# Usage:
#   sudo srvpulse install [--interactive]
#   sudo srvpulse uninstall
#   sudo srvpulse start
#   sudo srvpulse stop
#   sudo srvpulse status
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
META_DIR="/etc/srvpulse"
INSTALL_META="$META_DIR/install_dir"
STATE_DIR="/var/lib/srvpulse"
CRON_FILE="/etc/cron.d/srvpulse"
CRON_BACKUP="$STATE_DIR/cron.bak"
LOGROTATE_FILE="/etc/logrotate.d/srvpulse"
LOG_FILE="/var/log/srvpulse.log"
DEFAULT_INSTALL_DIR="/opt/srvpulse"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

INTERACTIVE=0
INSTALL_DIR=""
CONFIG_FILE=""
RUN_PYTHON=""
PYTHON=""

echo_info()  { echo -e "${GREEN}[INFO]${NC} $1"; }
echo_warn()  { echo -e "${YELLOW}[WARN]${NC} $1"; }
echo_error() { echo -e "${RED}[ERROR]${NC} $1"; }
echo_title() { echo -e "${CYAN}$1${NC}"; }

read_tty() {
    if [ -r /dev/tty ] && [ -w /dev/tty ]; then
        read -r "$@" </dev/tty
    else
        read -r "$@"
    fi
}

read_secret_tty() {
    if [ -r /dev/tty ] && [ -w /dev/tty ]; then
        read -rs "$@" </dev/tty
    else
        read -rs "$@"
    fi
}

can_interact() {
    [ "$INTERACTIVE" = "1" ] || [ -t 0 ] || { [ -r /dev/tty ] && [ -w /dev/tty ]; }
}

mask_secret() {
    local s="$1"
    local len=${#s}
    if [ "$len" -le 4 ]; then
        echo "****"
    else
        echo "${s:0:4}****"
    fi
}

require_root() {
    if [ "$EUID" -ne 0 ]; then
        echo_error "Please run as root: sudo srvpulse $*"
        exit 1
    fi
}

usage() {
    cat <<'EOF'
srvpulse - server resource monitor

Usage:
  sudo srvpulse install [--interactive|-i]   Install / update (deps, config, cron)
  sudo srvpulse uninstall                    Remove srvpulse completely
  sudo srvpulse start                        Enable scheduled monitoring (cron)
  sudo srvpulse stop                         Disable scheduled monitoring
  sudo srvpulse status                       Show install and runtime details

Examples:
  sudo git clone git@github.com:gejigang2008/srvpulse.git /opt/srvpulse
  cd /opt/srvpulse
  sudo ./srvpulse install
  sudo srvpulse status
  sudo srvpulse stop
  sudo srvpulse start
EOF
}

resolve_install_dir() {
    if [ -n "$INSTALL_DIR" ]; then
        return 0
    fi
    if [ -f "$INSTALL_META" ]; then
        INSTALL_DIR="$(tr -d '\r\n' < "$INSTALL_META")"
    elif [ -f "$SCRIPT_DIR/monitor.py" ]; then
        INSTALL_DIR="$SCRIPT_DIR"
    elif [ -f "$DEFAULT_INSTALL_DIR/monitor.py" ]; then
        INSTALL_DIR="$DEFAULT_INSTALL_DIR"
    else
        echo_error "srvpulse not installed (missing $INSTALL_META)"
        exit 1
    fi
    CONFIG_FILE="$INSTALL_DIR/config.yaml"
}

resolve_python() {
    if [ -n "$RUN_PYTHON" ]; then
        return 0
    fi
    PYTHON=$(command -v python3 || true)
    if [ -z "$PYTHON" ]; then
        echo_error "python3 not found, need Python 3.6+"
        exit 1
    fi
    RUN_PYTHON="$PYTHON"
}

cron_is_active() {
    [ -f "$CRON_FILE" ]
}

install_apt_packages() {
    local packages=("$@")
    if ! command -v apt-get >/dev/null 2>&1; then
        return 1
    fi
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq
    apt-get install -y "${packages[@]}"
}

ensure_system_pip() {
    resolve_python
    if $PYTHON -m pip --version >/dev/null 2>&1; then
        return 0
    fi
    echo_info "Installing python3-pip ..."
    if install_apt_packages python3-pip; then
        return 0
    fi
    echo_error "pip not available. Try: apt install python3-pip"
    exit 1
}

install_python_deps() {
    echo_info "Installing Python dependencies ..."

    if $PYTHON - <<'PY'
import sys
for mod in ("psutil", "requests", "yaml"):
    try:
        __import__(mod)
    except ImportError:
        sys.exit(1)
sys.exit(0)
PY
    then
        echo_info "Python dependencies already satisfied"
        return 0
    fi

    local err_file
    err_file="$(mktemp /tmp/srvpulse-pip.XXXXXX 2>/dev/null || echo /tmp/srvpulse-pip.err)"
    if $PYTHON -m pip install -r "$INSTALL_DIR/requirements.txt" -q 2>"$err_file"; then
        rm -f "$err_file"
        return 0
    fi

    if grep -qE "uninstall-distutils-installed-package|Cannot uninstall" "$err_file" 2>/dev/null; then
        echo_warn "System Python package conflict, retry with --ignore-installed ..."
        rm -f "$err_file"
        $PYTHON -m pip install --ignore-installed -r "$INSTALL_DIR/requirements.txt" -q
        return 0
    fi

    cat "$err_file" >&2
    rm -f "$err_file"
    echo_error "pip install failed"
    exit 1
}

setup_python_runtime() {
    if [ -d "$INSTALL_DIR/venv" ]; then
        echo_warn "Removing legacy venv directory ..."
        rm -rf "$INSTALL_DIR/venv"
    fi
    ensure_system_pip
    install_python_deps
}

load_feishu_config() {
    eval "$($RUN_PYTHON - "$CONFIG_FILE" <<'PY'
import shlex
import sys
import yaml

with open(sys.argv[1], encoding="utf-8") as f:
    cfg = yaml.safe_load(f) or {}

feishu = cfg.get("feishu", {})
url = str(feishu.get("webhook_url", "")).strip()
secret = str(feishu.get("secret", "")).strip()

placeholder = (
    not url
    or not secret
    or "xxxxxxxxxx" in url
    or secret == "YOUR_SECRET_KEY"
)

print("FEISHU_URL=" + shlex.quote(url))
print("FEISHU_SECRET=" + shlex.quote(secret))
print("FEISHU_IS_PLACEHOLDER=" + ("1" if placeholder else "0"))
PY
)"
}

save_feishu_config() {
    local webhook_url="$1"
    local secret="$2"

    WEBHOOK_URL="$webhook_url" SECRET="$secret" $RUN_PYTHON - "$CONFIG_FILE" <<'PY'
import os
import sys
import yaml

path = sys.argv[1]
with open(path, encoding="utf-8") as f:
    cfg = yaml.safe_load(f) or {}

cfg.setdefault("feishu", {})
cfg["feishu"]["webhook_url"] = os.environ["WEBHOOK_URL"]
cfg["feishu"]["secret"] = os.environ["SECRET"]

with open(path, "w", encoding="utf-8") as f:
    yaml.dump(cfg, f, allow_unicode=True, default_flow_style=False, sort_keys=False)
PY

    chmod 600 "$CONFIG_FILE"
    echo_info "Feishu config saved to $CONFIG_FILE"
}

interactive_feishu_config() {
    local default_url="${1:-}"
    local default_secret="${2:-}"
    local webhook_url secret url_default secret_default

    if [ -n "$default_url" ] && [[ "$default_url" != *"xxxxxxxxxx"* ]]; then
        url_default="$default_url"
    fi
    if [ -n "$default_secret" ] && [ "$default_secret" != "YOUR_SECRET_KEY" ]; then
        secret_default="$default_secret"
    fi

    echo ""
    echo_info "========================================"
    echo_info "  Feishu bot setup (required)"
    echo_info "========================================"
    echo_info "Get Webhook URL and Secret from Feishu group bot settings."
    echo ""

    if [ -n "$url_default" ]; then
        read_tty -p "Webhook URL [$url_default]: " webhook_url
        webhook_url="${webhook_url:-$url_default}"
    else
        read_tty -p "Webhook URL: " webhook_url
    fi

    if [ -n "$secret_default" ]; then
        read_secret_tty -p "Secret [$(mask_secret "$secret_default")] (Enter to keep): " secret
        secret="${secret:-$secret_default}"
    else
        read_secret_tty -p "Secret: " secret
    fi
    echo ""

    if [ -z "$webhook_url" ] || [ -z "$secret" ]; then
        echo_error "Webhook URL and Secret cannot be empty"
        exit 1
    fi
    if [[ "$webhook_url" == *"xxxxxxxxxx"* ]] || [ "$secret" = "YOUR_SECRET_KEY" ]; then
        echo_error "Please replace template placeholders with real Feishu values"
        exit 1
    fi

    save_feishu_config "$webhook_url" "$secret"
}

confirm_feishu_config() {
    echo ""
    echo_info "Current Feishu config:"
    echo "  Webhook URL: $FEISHU_URL"
    echo "  Secret:      $(mask_secret "$FEISHU_SECRET")"
    echo ""

    local answer
    read_tty -p "Use this config? [Y/n] " answer
    case "${answer:-Y}" in
        [Yy]*)
            echo_info "Feishu config confirmed"
            ;;
        [Nn]*)
            interactive_feishu_config "$FEISHU_URL" "$FEISHU_SECRET"
            ;;
        *)
            echo_error "Invalid input"
            exit 1
            ;;
    esac
}

ensure_feishu_config() {
    local config_just_created="${1:-0}"

    load_feishu_config

    if [ "$FEISHU_IS_PLACEHOLDER" = "0" ]; then
        if can_interact; then
            confirm_feishu_config
        else
            echo_info "Feishu config OK"
        fi
    else
        echo_warn "Feishu config incomplete (template placeholders in config.yaml)"

        if ! can_interact; then
            echo_error "No interactive terminal. Configure Feishu first:"
            echo "  vim $CONFIG_FILE"
            echo "  or: sudo srvpulse install --interactive"
            exit 1
        fi

        if [ "$config_just_created" = "1" ] || [ "$INTERACTIVE" = "1" ]; then
            interactive_feishu_config "$FEISHU_URL" "$FEISHU_SECRET"
        else
            local answer
            read_tty -p "Configure Feishu now? [Y/n] " answer
            case "${answer:-Y}" in
                [Yy]*)
                    interactive_feishu_config "$FEISHU_URL" "$FEISHU_SECRET"
                    ;;
                *)
                    echo_error "Feishu config is required. Either:"
                    echo "  sudo srvpulse install --interactive"
                    echo "  vim $CONFIG_FILE"
                    exit 1
                    ;;
            esac
        fi
    fi

    load_feishu_config
    if [ "$FEISHU_IS_PLACEHOLDER" = "1" ]; then
        echo_error "Feishu config still incomplete"
        exit 1
    fi
}

write_cron() {
    mkdir -p "$STATE_DIR"
    cat > "$CRON_FILE" << EOF
# srvpulse - every 5 minutes
*/5 * * * * root cd $INSTALL_DIR && $RUN_PYTHON monitor.py >> $LOG_FILE 2>&1
EOF
    chmod 644 "$CRON_FILE"
    rm -f "$CRON_BACKUP"
}

write_logrotate() {
    cat > "$LOGROTATE_FILE" << EOF
$LOG_FILE {
    daily
    rotate 7
    compress
    missingok
    notifempty
    copytruncate
}
EOF
    chmod 644 "$LOGROTATE_FILE"
}

install_cli_symlink() {
    mkdir -p "$META_DIR"
    echo "$INSTALL_DIR" > "$INSTALL_META"
    chmod 644 "$INSTALL_META"
    chmod +x "$INSTALL_DIR/srvpulse"
    ln -sf "$INSTALL_DIR/srvpulse" /usr/local/bin/srvpulse
    echo_info "CLI installed: /usr/local/bin/srvpulse"
}

cmd_install() {
    require_root install
    local config_just_created=0

    while [ $# -gt 0 ]; do
        case "$1" in
            --interactive|-i) INTERACTIVE=1 ;;
            -h|--help)
                echo "Usage: sudo srvpulse install [--interactive|-i]"
                exit 0
                ;;
            *)
                echo_error "Unknown option: $1"
                exit 1
                ;;
        esac
        shift
    done

    if [ -f "$SCRIPT_DIR/monitor.py" ]; then
        INSTALL_DIR="$SCRIPT_DIR"
    else
        echo_error "monitor.py not found, run inside srvpulse repo directory"
        exit 1
    fi
    CONFIG_FILE="$INSTALL_DIR/config.yaml"

    resolve_python
    PYTHON_VERSION=$($PYTHON --version 2>&1 | awk '{print $2}')
    echo_info "Python version: $PYTHON_VERSION"

    if ! $PYTHON -c 'import sys; raise SystemExit(0 if sys.version_info >= (3, 6) else 1)'; then
        echo_error "Python 3.6+ required, current: $PYTHON_VERSION"
        exit 1
    fi

    chmod +x "$INSTALL_DIR/monitor.py"
    echo_info "Install directory: $INSTALL_DIR"

    setup_python_runtime

    if [ ! -f "$CONFIG_FILE" ]; then
        cp "$INSTALL_DIR/config.yaml.example" "$CONFIG_FILE"
        chmod 600 "$CONFIG_FILE"
        config_just_created=1
        echo_info "Created config from template: $CONFIG_FILE"
    else
        echo_info "Config exists: $CONFIG_FILE"
    fi

    ensure_feishu_config "$config_just_created"

    echo_info "Validating config ..."
    if $RUN_PYTHON "$INSTALL_DIR/monitor.py" --check; then
        echo_info "Config validation passed"
    else
        echo_error "Config validation failed, check $CONFIG_FILE"
        exit 1
    fi

    echo_info "Configuring cron ..."
    write_cron

    echo_info "Configuring logrotate ..."
    write_logrotate

    install_cli_symlink

    echo ""
    echo_info "========================================"
    echo_info "  srvpulse install complete"
    echo_info "========================================"
    echo ""
    echo_info "Commands:"
    echo "  sudo srvpulse status      # view details"
    echo "  sudo srvpulse stop        # disable cron"
    echo "  sudo srvpulse start       # enable cron"
    echo "  sudo srvpulse uninstall   # remove all"
    echo ""
    echo_info "Verify:"
    echo "  $RUN_PYTHON $INSTALL_DIR/monitor.py --test"
    echo "  tail -f $LOG_FILE"
    echo ""
}

cmd_uninstall() {
    require_root uninstall

    resolve_install_dir

    echo_info "Removing cron ..."
    rm -f "$CRON_FILE" "$CRON_BACKUP"

    echo_info "Removing logrotate ..."
    rm -f "$LOGROTATE_FILE"

    echo_info "Removing CLI symlink ..."
    rm -f /usr/local/bin/srvpulse

    echo_info "Removing metadata ..."
    rm -rf "$META_DIR" "$STATE_DIR"

    echo_info "Removing install directory: $INSTALL_DIR"
    rm -rf "$INSTALL_DIR"

    echo_info "Removing log file ..."
    rm -f "$LOG_FILE"

    echo ""
    echo_info "srvpulse uninstalled"
}

cmd_start() {
    require_root start

    resolve_install_dir
    resolve_python

    if [ ! -f "$CONFIG_FILE" ]; then
        echo_error "Config not found: $CONFIG_FILE"
        exit 1
    fi

    if cron_is_active; then
        echo_info "srvpulse is already running (cron active)"
        return 0
    fi

    echo_info "Starting srvpulse (enabling cron) ..."
    write_cron
    echo_info "Cron enabled: $CRON_FILE"
}

cmd_stop() {
    require_root stop

    resolve_install_dir

    if ! cron_is_active; then
        echo_info "srvpulse is already stopped (no cron)"
        return 0
    fi

    mkdir -p "$STATE_DIR"
    cp "$CRON_FILE" "$CRON_BACKUP"
    rm -f "$CRON_FILE"
    echo_info "srvpulse stopped (cron disabled)"
    echo_info "Backup saved: $CRON_BACKUP"
}

cmd_status() {
    local state_file log_mtime cron_status python_version

    echo_title "========== srvpulse status =========="
    echo ""

    if [ -f "$INSTALL_META" ]; then
        INSTALL_DIR="$(tr -d '\r\n' < "$INSTALL_META")"
        echo "Install dir:    $INSTALL_DIR"
        echo "Metadata:       $INSTALL_META"
    elif [ -f "$SCRIPT_DIR/monitor.py" ]; then
        INSTALL_DIR="$SCRIPT_DIR"
        echo "Install dir:    $INSTALL_DIR (not registered, run install)"
    else
        echo "Install dir:    (not installed)"
        echo ""
        echo_error "srvpulse is not installed"
        exit 1
    fi

    CONFIG_FILE="$INSTALL_DIR/config.yaml"
    state_file="$INSTALL_DIR/state.json"

    if cron_is_active; then
        cron_status="${GREEN}running${NC} ($CRON_FILE)"
    else
        cron_status="${YELLOW}stopped${NC}"
        if [ -f "$CRON_BACKUP" ]; then
            cron_status="$cron_status (backup: $CRON_BACKUP)"
        fi
    fi
    echo -e "Scheduler:      $cron_status"

    if command -v python3 >/dev/null 2>&1; then
        python_version="$(python3 --version 2>&1)"
        echo "Python:         $python_version ($(command -v python3))"
    else
        echo "Python:         (not found)"
    fi

    if [ -f "$CONFIG_FILE" ]; then
        echo "Config:         $CONFIG_FILE"
        resolve_python
        load_feishu_config
        if [ "$FEISHU_IS_PLACEHOLDER" = "0" ]; then
            echo "Feishu URL:     $FEISHU_URL"
            echo "Feishu Secret:  $(mask_secret "$FEISHU_SECRET")"
        else
            echo -e "Feishu:         ${YELLOW}not configured${NC}"
        fi
    else
        echo -e "Config:         ${YELLOW}missing${NC}"
    fi

    if [ -f "$state_file" ]; then
        echo "State file:     $state_file"
    else
        echo "State file:     (not created yet)"
    fi

    if [ -f "$LOG_FILE" ]; then
        log_mtime="$(stat -c '%y' "$LOG_FILE" 2>/dev/null || stat -f '%Sm' "$LOG_FILE" 2>/dev/null || echo unknown)"
        echo "Log file:       $LOG_FILE (modified: $log_mtime)"
    else
        echo "Log file:       $LOG_FILE (not created yet)"
    fi

    if [ -L /usr/local/bin/srvpulse ] || [ -f /usr/local/bin/srvpulse ]; then
        echo "CLI:            /usr/local/bin/srvpulse -> $(readlink -f /usr/local/bin/srvpulse 2>/dev/null || echo srvpulse)"
    else
        echo "CLI:            (not linked, run install)"
    fi

    echo ""
    if [ -f "$LOG_FILE" ]; then
        echo_title "--- Recent log (last 10 lines) ---"
        tail -n 10 "$LOG_FILE" 2>/dev/null || true
        echo ""
    fi

    if [ -f "$CONFIG_FILE" ] && [ -f "$INSTALL_DIR/monitor.py" ]; then
        resolve_python
        echo_title "--- Config check ---"
        $RUN_PYTHON "$INSTALL_DIR/monitor.py" --check 2>&1 || true
        echo ""
    fi

    echo_title "========== end =========="
}

main() {
    local cmd="${1:-}"

    case "$cmd" in
        install)   shift; cmd_install "$@" ;;
        uninstall) shift; cmd_uninstall "$@" ;;
        start)     shift; cmd_start "$@" ;;
        stop)      shift; cmd_stop "$@" ;;
        status|info)
            shift
            cmd_status "$@"
            ;;
        -h|--help|help)
            usage
            ;;
        "")
            usage
            exit 1
            ;;
        *)
            echo_error "Unknown command: $cmd"
            echo ""
            usage
            exit 1
            ;;
    esac
}

main "$@"
